{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "proseWrap": "preserve",
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.yarn/**",
    "default-build-script/**",
    "test-runner/**",
    "platforms/**"
  ]
}
